# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/onesign"

# NextAuth Configuration
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Application Configuration
APP_URL="http://localhost:3000"
NODE_ENV="development"

# SMTP Configuration (Email Service)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="noreply@onesign.app"

# Optional: Resend Email Service (Alternative to SMTP)
# RESEND_API_KEY="re_xxxxxxxxxxxxx"

# Optional: SendGrid Integration
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxx"

# AWS S3 Configuration (for document storage - optional)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="onesign-documents"
# AWS_REGION="us-east-1"

# Google OAuth (optional for social login)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth (optional for social login)
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# Analytics (optional)
# NEXT_PUBLIC_GA_ID="G-xxxxxxxxxx"

# Feature Flags
NEXT_PUBLIC_FEATURE_TEMPLATES="true"
NEXT_PUBLIC_FEATURE_BULK_SIGNING="true"
